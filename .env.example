# =============================================
#  FERROMAX ERP — Plantilla de variables de entorno
#  Copiá este archivo como .env y completá los valores reales
#  NUNCA commitear el archivo .env
# =============================================

# ----- Base de datos -----
DB_URL=jdbc:postgresql://localhost:5432/ferromax_db
DB_USERNAME=postgres
DB_PASSWORD=REEMPLAZAR_CON_TU_PASSWORD

# ----- JWT (usar una cadena larga y aleatoria, mínimo 32 caracteres) -----
# Generar con: openssl rand -base64 48
JWT_SECRET=REEMPLAZAR_CON_CLAVE_SECRETA_LARGA
JWT_EXPIRATION_MS=28800000
JWT_REFRESH_EXPIRATION_MS=604800000

# ----- Google Gemini -----
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REEMPLAZAR_CON_TU_API_KEY

# ----- OCR.space -----
# Key gratuita en: https://ocr.space/ocrapi
# La key "helloworld" funciona para pruebas con límite bajo
OCR_SPACE_API_KEY=helloworld

# ----- Webhook de pasarela de pagos -----
# Obtener desde el dashboard de MercadoPago/Stripe al configurar el webhook
WEBHOOK_SECRET=REEMPLAZAR_CON_SECRET_DE_LA_PASARELA
